# Backend Production Environment Template
# Copy this file to .env and fill in actual values
# SECURITY: Never commit .env to version control

# Node Environment
NODE_ENV=production
PORT=5000

# Database
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/safestay-hub?retryWrites=true&w=majority
MONGO_MAX_RETRIES=5
MONGO_RETRY_DELAY=5000
MONGO_SELECTION_TIMEOUT=5000

# Authentication
JWT_SECRET=____GENERATE_STRONG_32_CHAR_STRING____ (min 32 characters)
JWT_EXPIRE=7d

# Frontend Configuration
FRONTEND_URL=https://your-vercel-domain.vercel.app

# Cloudinary (Image hosting)
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET=your_api_secret_here

# Razorpay (Payments - REQUIRED)
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here

# Twilio (SMS/OTP - Optional)
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# Email Configuration (Optional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password

# Mapbox Token (Maps)
VITE_MAPBOX_TOKEN=your_mapbox_token_here

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX=600
RATE_LIMIT_WINDOW_MS=900000

# Server Configuration
LOG_LEVEL=info
HEALTH_CHECK_INTERVAL=10000
REQUEST_TIMEOUT=30000
MAX_QUEUE_SIZE=1000
MAX_CONCURRENT=100

# ========================================
# IMPORTANT: PRODUCTION SECURITY NOTES
# ========================================
# 1. Use strong JWT_SECRET (min 32 chars, random)
# 2. Rotate all API keys and secrets
# 3. Use IP whitelist on MongoDB
# 4. Enable HTTPS on frontend (Vercel handles this)
# 5. Set up monitoring and alerts
# 6. Regular backups of MongoDB
# 7. Monitor API rate limits during high traffic
# 8. Keep dependencies updated
