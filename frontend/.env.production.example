# Frontend Production Environment Template
# Copy this file to .env.production and fill in actual values
# SECURITY: Never commit .env files to version control

# API Configuration
VITE_API_URL=https://your-railway-app.up.railway.app

# Mapbox Token (Maps & Location features)
VITE_MAPBOX_TOKEN=your_mapbox_token_here

# Application Configuration
VITE_APP_NAME=SafeStay Hub
VITE_APP_VERSION=1.0.0

# Feature Flags (Optional)
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_SENTRY=false
VITE_DEBUG_MODE=false

# ========================================
# IMPORTANT: PRODUCTION SETUP NOTES
# ========================================
# 1. VITE_API_URL must point to Railway backend
# 2. Ensure MAPBOX token is valid and enabled for web
# 3. Use Vercel environment variables, not local .env
# 4. Never commit .env files to git
# 5. Verify all API endpoints work in production
# 6. Test real-time features (Socket.IO)
# 7. Test payment flow with Razorpay
# 8. Monitor frontend errors via Vercel dashboard
#
# Example production VITE_API_URL:
# https://safestay-api-production.up.railway.app
